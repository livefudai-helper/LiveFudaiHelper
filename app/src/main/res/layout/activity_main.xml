<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="检查无障碍服务状态..."
        android:textSize="18sp"
        android:layout_marginBottom="32dp"/>

    <Button
        android:id="@+id/enable_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="开启无障碍服务"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/screenshot_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="开启截图识别"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/screenshot_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="截图识别：未开启"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/blind_click_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="开启盲点击模式"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/blind_click_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="盲点击：未开启"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/test_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="测试 OCR"/>

</LinearLayout>
