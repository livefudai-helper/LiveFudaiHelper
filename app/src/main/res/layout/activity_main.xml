<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎁 福袋自动助手"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@color/primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="自动识别并参与直播间福袋"
            android:textSize="14sp"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="32dp" />

        <!-- 服务状态卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="服务状态"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <LinearLayout
                    android:id="@+id/layoutStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="12dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="服务未启动"
                        android:textSize="16sp"
                        android:textColor="@color/error" />

                </LinearLayout>

                <Button
                    android:id="@+id/btnToggleService"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="启动服务"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="@color/primary"
                    android:textColor="@color/white" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 功能说明卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="核心功能"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✅ 自动识别直播间福袋"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✅ 倒计时≤3分钟时自动参与"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✅ 自动完成关注/评论要求"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✅ 支持抖音/快手/QQ直播"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnConfigure"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚙️ 高级配置"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/secondary"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnTestOCR"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🧪 测试OCR识别"
                android:layout_marginBottom="12dp"
                android:backgroundTint="@color/secondary"
                android:textColor="@color/white" />

            <Button
                android:id="@+id/btnHelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📖 使用说明"
                android:backgroundTint="@color/secondary"
                android:textColor="@color/white" />

        </LinearLayout>

        <!-- 免责声明 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ 免责声明：本工具仅供学习交流，请遵守平台规则"
            android:textSize="12sp"
            android:gravity="center"
            android:textColor="@color/text_hint"
            android:layout_marginTop="32dp" />

    </LinearLayout>

</ScrollView>
