<resources>
    <string name="app_name">福袋自动助手</string>
    
    <!-- 无障碍服务描述 -->
    <string name="accessibility_service_description">
        自动识别并参与直播间福袋工具。
        \n\n功能：
        \n• 监听直播间界面变化
        \n• 自动识别福袋倒计时
        \n• 倒计时≤3分钟时自动参与
        \n• 自动完成福袋要求（关注/评论等）
        \n\n使用方法：
        \n1. 开启此服务
        \n2. 打开抖音/快手等直播APP
        \n3. 进入直播间，等待福袋出现
        \n4. 工具会自动识别并参与
        \n\n注意事项：
        \n• 请保持屏幕常亮
        \n• 过度使用可能被平台检测
        \n• 仅供学习交流，请遵守平台规则
    </string>
    
